# MCP Hub Configuration
MH_DATABASE_URL=postgresql+asyncpg://mcphub:mcphub@localhost:5432/mcphub
MH_DEBUG=false
MH_HOST=0.0.0.0
MH_PORT=8500

# Proxy — connects to upstream MCP servers and re-exposes their tools
MH_PROXY_ENABLED=true
MH_UPSTREAMS_CONFIG=upstreams.yaml

# GitLab (local instance — built-in tools)
MH_GITLAB_URL=http://gitlab.steelcanvas.dev
MH_GITLAB_TOKEN=

# Kubernetes (uses in-cluster config or ~/.kube/config)
MH_KUBE_CONFIG=~/.kube/config

# ── Upstream API Keys ──────────────────────────────────────────
# Set these to enable the corresponding upstream MCP servers.
# Servers with no API key requirement are enabled by default.

# Search
MH_BRAVE_API_KEY=
MH_TAVILY_API_KEY=
MH_EXA_API_KEY=

# Code
MH_GITHUB_TOKEN=

# AI / ML
MH_OPENAI_API_KEY=
MH_HF_TOKEN=

# Knowledge
MH_WOLFRAM_APP_ID=

# Communication
MH_SLACK_BOT_TOKEN=
MH_DISCORD_TOKEN=
MH_LINEAR_API_KEY=
MH_NOTION_API_KEY=

# Monitoring
MH_PROMETHEUS_URL=http://prometheus.steelcanvas.dev
MH_GRAFANA_URL=http://grafana.steelcanvas.dev
MH_GRAFANA_API_KEY=
MH_SENTRY_TOKEN=

# Databases
MH_PROXY_POSTGRES_URL=
MH_REDIS_URL=
MH_SQLITE_PATH=
MH_QDRANT_URL=
MH_QDRANT_API_KEY=

# Storage
MH_S3_ACCESS_KEY=
MH_S3_SECRET_KEY=
MH_S3_ENDPOINT=

# Cloud
MH_CLOUDFLARE_TOKEN=

# Infrastructure
MH_ARGOCD_URL=https://argocd.steelcanvas.dev
MH_ARGOCD_TOKEN=
MH_LOKI_URL=http://loki.steelcanvas.dev
MH_VAULT_URL=http://vault.steelcanvas.dev
MH_VAULT_TOKEN=
MH_SONARQUBE_URL=http://sonarqube.steelcanvas.dev
MH_SONARQUBE_TOKEN=
MH_NETBOX_URL=http://netbox.steelcanvas.dev
MH_NETBOX_TOKEN=
MH_PROXMOX_URL=https://192.168.1.10:8006
MH_PROXMOX_TOKEN_ID=root@pam!mcp-hub
MH_PROXMOX_TOKEN_SECRET=
MH_N8N_URL=http://n8n.steelcanvas.dev
MH_N8N_API_KEY=
